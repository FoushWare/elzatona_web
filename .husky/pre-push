###############################################################################
# Utility: timed check runner
###############################################################################
run_check() {
  local name="$1"
  local command="$2"
  local fix_hint="$3"

  local start end duration exit_code

  echo ""
  echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"
  echo "рџ“‹ $name"
  echo "рџ§Є $command"
  echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"
  echo ""

  start=$(date +%s)

  {
    echo "[$(date +"%H:%M:%S")] START $name"
    bash -c "$command"
    exit_code=$?
    echo "[$(date +"%H:%M:%S")] END $name (exit=$exit_code)"
    return $exit_code
  } >>"$LOG_FILE" 2>&1

  exit_code=$?
  end=$(date +%s)
  duration=$((end - start))
  CHECK_DURATIONS+=("$name: ${duration}s")

  if [ $exit_code -eq 0 ]; then
    echo -e "${GREEN}вњ… $name passed (${duration}s)${NC}"
    PASSED_CHECKS+=("$name")
  else
    echo -e "${RED}вќЊ $name failed (${duration}s)${NC}"
    FAILED_CHECKS+=("$name")

    [ -n "$fix_hint" ] && echo -e "${YELLOW}рџ’Ў $fix_hint${NC}"

    echo -e "${BLUE}рџ“„ Log tail (last 40 lines):${NC}"
    tail -n 40 "$LOG_FILE" | sed 's/^/   /'
    echo -e "${RED}рџ”Ћ Check '$name' failed with exit code $exit_code${NC}"
    echo -e "${CYAN}рџ“„ Full log: $LOG_FILE${NC}"
  fi

  return $exit_code
}

###############################################################################
# STEP 0: Secret Scanning (FAIL FAST)
###############################################################################
echo "STEP 0: Secret Scanning"

if command -v gitleaks >/dev/null 2>&1; then
  # Create temporary directory with staged files only
  STAGED_DIR=$(mktemp -d)
  git diff --cached --name-only --diff-filter=AM | while read file; do
    if [ -f "$file" ]; then
      mkdir -p "$STAGED_DIR/$(dirname "$file")"
      cp "$file" "$STAGED_DIR/$file"
    fi
  done
  
  run_check \
    "Secret Scan (Gitleaks)" \
    "cd '$STAGED_DIR' && gitleaks detect --redact --exit-code 1 --no-git --source . && cd -" \
    "Remove secrets and rotate compromised credentials"
  
  # Clean up temporary directory
  rm -rf "$STAGED_DIR"
else
  echo -e "${YELLOW}вљ пёЏ  Gitleaks not installed вЂ” skipping secret scan${NC}"
  echo -e "${YELLOW}рџ’Ў Install: https://github.com/gitleaks/gitleaks${NC}"
fi

